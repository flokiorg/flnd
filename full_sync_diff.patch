-; connection to a target peer. This is recommended as there aren't many
-; neutrino compliant full nodes on the test network yet.
-; neutrino.connect=
-
-; Max number of inbound and outbound peers.
-; neutrino.maxpeers=8
-
-; Add a peer to connect with at startup.
-; neutrino.addpeer=
-
