+		// Query random nodes to avoid query caching and better
+		// represent real-world query patterns.
+		nodePub := nodes[rng.Intn(len(nodes))].PubKeyBytes
+		_, err := graph.IsPublicNode(nodePub)
+		require.NoError(b, err)
